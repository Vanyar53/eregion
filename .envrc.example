# Eregion — variables d'environnement
# Copier ce fichier en .envrc et remplir les valeurs
# cp .envrc.example .envrc

# ── LLM provider ──────────────────────────────────────────────────────────────
# Défaut : Anthropic Claude. Changer pour utiliser un autre provider.
#
# Anthropic (défaut)
export ANTHROPIC_API_KEY=sk-ant-...
# export GLORFINDEL_LLM_MODEL=anthropic/claude-sonnet-4-6
#
# OpenAI
# export GLORFINDEL_LLM_MODEL=openai/gpt-4o
# export OPENAI_API_KEY=sk-...
#
# Azure OpenAI
# export GLORFINDEL_LLM_MODEL=azure/gpt-4o
# export AZURE_API_KEY=...
# export AZURE_API_BASE=https://<resource>.openai.azure.com
# export AZURE_API_VERSION=2024-02-01
#
# Ollama (local / air-gap)
# export GLORFINDEL_LLM_MODEL=ollama/llama3.1
# export GLORFINDEL_LLM_BASE_URL=http://localhost:11434
#
# Mistral AI (API cloud)
# export GLORFINDEL_LLM_MODEL=mistral/mistral-large-latest
# export MISTRAL_API_KEY=...
#
# Tout endpoint OpenAI-compatible (vLLM, LM Studio, Mistral self-hosted...)
# export GLORFINDEL_LLM_MODEL=openai/mistral-7b
# export GLORFINDEL_LLM_BASE_URL=http://my-server:8000

# ── Azure — Service Principal ──────────────────────────────────────────────────
#
# Option A — SP unique Contributor (démarrage rapide)
# az ad sp create-for-rbac --name "eregion" --role Contributor \
#                           --scopes /subscriptions/<SUBSCRIPTION_ID>
# Retourne : appId (CLIENT_ID), password (CLIENT_SECRET), tenant (TENANT_ID)
#
export AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
export AZURE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
export AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# az account show --query id -o tsv
export AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Option B — SPs séparés (Glorfindel Reader + Annatar Contributor)
# Utiliser pour tester le mode observe-only sans bloquer Annatar.
# Annatar a besoin de Contributor (RunCommand). Glorfindel peut tourner en
# Reader + Log Analytics Reader (GLORFINDEL_READ_ONLY=1, human_only par défaut).
#
# SP Glorfindel — Reader + Log Analytics Reader
# az ad sp create-for-rbac --name "glorfindel" --role Reader \
#                           --scopes /subscriptions/<SUBSCRIPTION_ID>
# az role assignment create --assignee <appId> \
#   --role "Log Analytics Reader" --scope /subscriptions/<SUBSCRIPTION_ID>
# export GLORFINDEL_AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# export GLORFINDEL_AZURE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# export GLORFINDEL_AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#
# SP Annatar — Contributor
# az ad sp create-for-rbac --name "annatar" --role Contributor \
#                           --scopes /subscriptions/<SUBSCRIPTION_ID>
# export ANNATAR_AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# export ANNATAR_AZURE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# export ANNATAR_AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#
# Note : docker compose utilise AZURE_CLIENT_* directement (Glorfindel uniquement).
# En Option B, pointer AZURE_CLIENT_* vers le SP Glorfindel Reader :
# export AZURE_CLIENT_ID=$GLORFINDEL_AZURE_CLIENT_ID
# export AZURE_CLIENT_SECRET=$GLORFINDEL_AZURE_CLIENT_SECRET
# export AZURE_TENANT_ID=$GLORFINDEL_AZURE_TENANT_ID
# Les commandes `make annatar-*` liront ANNATAR_AZURE_* avec fallback sur AZURE_*.

# ── Glorfindel — détection continue (detection_rules.yaml) ───────────────────
# Ces variables résolvent les placeholders ${...} dans detection_rules.yaml.
# Elles ne sont nécessaires que si tu utilises glorfindel/rules/azure/detection_rules.yaml.
#
# AZURE_WORKSPACE_ID : GUID du Log Analytics Workspace (pas le resource ID complet)
#   az monitor log-analytics workspace show -g <rg> -n <workspace> --query customerId -o tsv
export AZURE_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#
# AZURE_VM_RESOURCE_ID : resource ID complet de la VM cible
#   az vm show -g <rg> -n <vm> --query id -o tsv
export AZURE_VM_RESOURCE_ID=/subscriptions/<SUBSCRIPTION_ID>/resourceGroups/<RG>/providers/Microsoft.Compute/virtualMachines/<VM_NAME>

# ── Glorfindel — optionnel ────────────────────────────────────────────────────
# Slack / Teams / Discord webhook — actions autonomes (one-way)
# Slack/Teams :
# export GLORFINDEL_WEBHOOK_URL=https://hooks.slack.com/services/...
# Discord (ajouter /slack à la fin de l'URL webhook Discord) :
# export GLORFINDEL_WEBHOOK_URL=https://discord.com/api/webhooks/<id>/<token>/slack

# Discord Bot — escalades interactives (boutons, /pending)
# Créer sur https://discord.com/developers/applications → New Application → Bot
# Inviter avec scopes: bot + applications.commands, permissions: Send Messages + Read Messages
# DISCORD_CHANNEL_ID : clic droit sur le channel → Copy Channel ID (activer Developer Mode)
# export DISCORD_BOT_TOKEN=...
# export DISCORD_CHANNEL_ID=...
# export DISCORD_PING_ROLE=...    # ID du rôle à pinger à l'ouverture d'un fil (ex: @oncall)

# TTL isolation (défaut 4h) — mettre 0 pour désactiver
# export GLORFINDEL_ISOLATION_TTL_H=4

# Fenêtre incident multi-signal (défaut 300s)
# export GLORFINDEL_INCIDENT_TTL_S=300

# Mode forensique — ne pas libérer automatiquement
# export GLORFINDEL_KEEP_ISOLATED=1

# Mode observe-only — SP Reader (pas Contributor) — aucune action write exécutée
# Combine avec human_only (défaut) pour un déploiement zéro-risque en évaluation.
# Voir CLAUDE.md → "Mode observe-only" pour le workflow complet.
# export GLORFINDEL_READ_ONLY=1

# ── Divers ────────────────────────────────────────────────────────────────────
# Supprime les logs ONNX Runtime (ChromaDB)
export ORT_LOGGING_LEVEL_DEFAULT=3
