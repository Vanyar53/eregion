# Glorfindel infrastructure configuration
# Copy to glorfindel-config.yaml and fill in your values.
# This file is mounted as a Docker volume — edit directly, no ${VAR} needed.
#
# Credentials (AZURE_CLIENT_ID, AZURE_CLIENT_SECRET, ANTHROPIC_API_KEY...)
# stay in .envrc or environment variables — not here.

# ── Monitoring backends ────────────────────────────────────────────────────────
# Detection sources. Glorfindel will query these to detect attacks AND
# discover which assets are protected (via Heartbeat/equivalent).

monitoring_backends:
  - name: law-annatar
    type: azure_monitor
    # az monitor log-analytics workspace show -g <rg> -n <name> --query customerId -o tsv
    workspace_id: "YOUR_LAW_WORKSPACE_GUID"
    discovery:
      enabled: true
      interval_s: 1800    # rediscover every 30 min

  # Example: Prometheus backend (uncomment to enable)
  # - name: prometheus-local
  #   type: prometheus
  #   workspace_id: "http://localhost:9090"
  #   discovery:
  #     enabled: false    # Prometheus discovery not yet implemented

# ── Action backends ────────────────────────────────────────────────────────────
# Targets for remediation actions (restore, backup checks...).
# Not used for detection — no queries run against these.

action_backends:
  - name: rsv-annatar
    type: azure_backup_vault
    vault_name: "rsv-annatar"
    resource_group: "annatar"

# ── Exceptions ────────────────────────────────────────────────────────────────
# Opt-out specific assets from auto-discovered monitoring.
# Uses fnmatch patterns (*, ?, [...] supported).

exceptions: []

  # Example: exclude all dev VMs from all rules
  # - asset_pattern: "vm-dev-*"
  #   exclude_all: true

  # Example: exclude a specific VM from one rule only
  # - asset_pattern: "vm-staging"
  #   exclude_rules: [ssh-brute-force]

# ── Autonomy ────────────────────────────────────────────────────────────────────
# How much Glorfindel is allowed to ACT on its own, resolved per asset.
#
#   human_only     (default) — nothing executes. Every action, even reversible
#                  ones (isolate_vm/block/snapshot), is recommended and escalated.
#                  ⚠ Detection without response until a human acts — only use on
#                  critical assets if escalations are watched (webhook/bot/War Room).
#   non_disruptive — current behaviour: reversible actions run autonomously,
#                  destructive actions are always gated.
#   full_auto      — deferred; refused by config validation for now.
#
# Resolution order: matching asset rule > global default. Unknown assets fall
# back to the global default (never accidental escalation to a more permissive mode).
# Start in human_only, observe what Glorfindel WOULD do on your real infra, then
# promote assets to non_disruptive once you trust it.
#
# Observe-only deployment: human_only only reads (detection/investigate/discovery).
# It runs on a Reader / Log Analytics Reader service principal — no Contributor
# needed. Set GLORFINDEL_READ_ONLY=1 to declare read-only creds: write actions
# then fail fast with a clear error instead of an opaque Azure 403.

autonomy:
  default: human_only
  # allow_destructive is a SEPARATE axis from the mode — delete/wipe are never
  # controlled by a mode. Empty = never autonomous, regardless of mode.
  allow_destructive: []
  assets: []
    # Example: dev VMs act autonomously, the prod DB stays human-gated
    # - match: "vm-dev-*"
    #   mode: non_disruptive
    # - match: "vm-prod-db"
    #   mode: human_only
